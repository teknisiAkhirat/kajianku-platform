# ============================================================
# Teknisi.Akhirat — Environment Variables (contoh)
# Salin file ini menjadi `.env` lalu isi dengan value asli.
# JANGAN commit file `.env` (sudah di-ignore oleh .gitignore).
# ============================================================

# --- Supabase (Lovable Cloud) — client-side (Vite) ---
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id_here

# --- Supabase — server-side / SSR fallback ---
SUPABASE_URL=your_supabase_url_here
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
SUPABASE_PROJECT_ID=your_supabase_project_id_here

# --- Google Gemini API (untuk generate caption) ---
# Dapatkan di: https://aistudio.google.com/app/apikey
# Dipakai hanya di server (Pages Function) — JANGAN gunakan prefix VITE_
# karena itu akan meng-expose key ke browser.
GEMINI_API_KEY=your_gemini_api_key_here
