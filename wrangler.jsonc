{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kajianku-platform",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "alias": {
    "#tanstack-router-entry": "./.wrangler/tanstack-aliases/router-entry.mjs",
    "#tanstack-start-entry": "./.wrangler/tanstack-aliases/start-entry.mjs",
    "#tanstack-start-plugin-adapters": "./.wrangler/tanstack-aliases/plugin-adapters.mjs",
    "tanstack-start-manifest:v": "./.wrangler/tanstack-aliases/start-manifest.mjs",
    "tanstack-start-injected-head-scripts:v": "./.wrangler/tanstack-aliases/injected-head-scripts.mjs"
  },
  "main": "src/server.ts",
  "build": {
    "command": "bun run build:wrangler",
    "watch_dir": ["src"]
  }
}
